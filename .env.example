# Ghostinator — variables d'environnement (dev). Copier en .env (git-ignoré).

# --- API dev (Express fallback) ---
PORT=8787
VITE_API_URL=http://127.0.0.1:8787

# --- Backend Supabase (optionnel en dev — sans, mode JSON local) ---
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Realtime côté client (push WebSocket via Supabase channels) ---
# Anon key = clé publique, OK d'embarquer dans le bundle. RLS bloque les écritures.
# VITE_SUPABASE_URL=https://your-project.supabase.co
# VITE_SUPABASE_ANON_KEY=eyJhbGciOi...

# --- Anti-bot Cloudflare Turnstile (optionnel en dev — sans, vérification désactivée) ---
# VITE_TURNSTILE_SITE_KEY=0xAAAAAAAAAA...
# TURNSTILE_SECRET_KEY=0xAAAAAAAAAA...

# --- Rate-limit côté serveur (Worker / Express) ---
# RATELIMIT_SECRET=change-me-and-rotate-daily-in-prod

# --- Cible déploiement Worker (utilisée par wrangler) ---
# CF_ACCOUNT_ID=...
# CF_API_TOKEN=...
