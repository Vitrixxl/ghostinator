{
  "name": "ghostinator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c red,blue \"node server/index.js\" \"vite --host 127.0.0.1 --port 5173\"",
    "dev:api": "node server/index.js",
    "dev:web": "vite --host 127.0.0.1 --port 5173",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "npm run preview",
    "cf:dev": "wrangler dev worker/src/index.js --local --port 8787",
    "cf:deploy": "wrangler deploy",
    "lint": "tsc -b --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/crypto.test.ts",
    "test:e2e": "vitest run tests/e2e-story-critique.test.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.87.1",
    "@vitejs/plugin-react": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.4.22",
    "concurrently": "^9.2.1",
    "happy-dom": "^20.9.0",
    "node-addon-api": "^8.7.0",
    "node-gyp": "^12.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "vite": "^7.2.7",
    "vitest": "^4.1.5",
    "wrangler": "^4.56.0"
  }
}
